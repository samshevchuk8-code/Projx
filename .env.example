# Atelier — AI Website Builder
# -----------------------------------------------------------------------------
# Everything here is OPTIONAL. With no config at all, the app runs in
# bring-your-own-key mode: each visitor pastes their OWN AI key (a free Google
# Gemini key or an Anthropic key) and the server never needs a key of its own.

# Port the server runs on (optional, defaults to 3000)
PORT=3000

# Models (optional)
MODEL=claude-sonnet-4-6           # used for Anthropic keys (sk-ant-…)
GEMINI_MODEL=gemini-2.5-flash     # used for Gemini keys (AIza…)

# --- Free managed AI agent (optional) ----------------------------------------
# Set SERVER_AI_KEY to offer a free, no-key-needed agent powered by YOUR key,
# metered against a per-visitor token allowance. Tip: a Google Gemini key
# (AIza…) has a permanently free tier, making this genuinely free to run.
# When the allowance is used up, the agent is paywalled (HTTP 402) and visitors
# upgrade (links below) or paste their own key for unlimited use.
# SERVER_AI_KEY=AIza...                 # or sk-ant-...

# --- Usage-based billing -----------------------------------------------------
# Every visitor starts on Free with a monthly token allowance. When it's spent,
# they pick a paid plan. Each paid plan INCLUDES a monthly allowance; going over
# is billed as overage — only for how much they exceed it, per 1,000 tokens.
# Allowances reset each calendar month. (Demo-grade, in-memory — see README.)
FREE_TOKEN_QUOTA=100000                  # Free plan: tokens / month (hard stop)
PRO_TOKENS=2000000                       # Pro plan: included tokens / month
PRO_OVERAGE_PER_1K=0.002                 # Pro: $ per 1,000 tokens over the plan
STUDIO_TOKENS=10000000                   # Studio plan: included tokens / month
STUDIO_OVERAGE_PER_1K=0.0015             # Studio: $ per 1,000 tokens over the plan

# Demo only: lets POST /api/activate-plan set a paid plan WITHOUT real payment,
# so the billing flow is testable. In production, leave this OFF and set the
# plan from a verified Stripe webhook instead.
# ALLOW_DEV_BILLING=1

# --- Monetization links (optional) -------------------------------------------
# Stripe Payment Links for the paid plans (create at dashboard.stripe.com).
STRIPE_PRO_LINK=
STRIPE_STUDIO_LINK=

# Checkout links for add-ons.
COURSE_LINK=                            # course enrollment / checkout URL
MARKETING_LINK=                         # marketing toolkit checkout URL

# Domain search/registration. Use {domain} as a placeholder for the query, e.g.
# https://www.namecheap.com/domains/registration/results/?domain={domain}
# If unset, the landing page shows a demo availability check + a registrar link.
DOMAIN_SEARCH_LINK=

# --- Your own AI API gateway (OpenAI-compatible) -----------------------------
# Turns this app into YOUR AI endpoint at /v1, backed by the SERVER_AI_KEY model
# (e.g. a free Gemini key) and protected by API keys you issue. Off unless
# enabled; auto-enables when SERVER_AI_KEY is set.
# GATEWAY_ENABLED=1                      # force on/off (1/0); defaults to on if SERVER_AI_KEY is set
# GATEWAY_KEYS=atl_live_yourkey1,atl_live_yourkey2   # the bearer key(s) callers must present
# (If enabled with no GATEWAY_KEYS, a random key is generated and printed at startup.)
