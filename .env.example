# This app is "bring your own key": each visitor enters their OWN AI key in the
# browser (a free Google Gemini key, or an Anthropic key), so the server does
# NOT need a key of its own. There is nothing required to put here.

# Port the server runs on (optional, defaults to 3000)
PORT=3000

# Anthropic model, used when a visitor pastes an Anthropic key (optional)
MODEL=claude-sonnet-4-6

# Gemini model, used when a visitor pastes a free Google Gemini key (optional)
GEMINI_MODEL=gemini-2.5-flash
