# Atelier — AI Website Builder
# -----------------------------------------------------------------------------
# Everything here is OPTIONAL. With no config at all, the app runs in
# bring-your-own-key mode: each visitor pastes their OWN AI key (a free Google
# Gemini key or an Anthropic key) and the server never needs a key of its own.

# Port the server runs on (optional, defaults to 3000)
PORT=3000

# Models (optional)
MODEL=claude-sonnet-4-6           # used for Anthropic keys (sk-ant-…)
GEMINI_MODEL=gemini-2.5-flash     # used for Gemini keys (AIza…)

# --- Free managed AI agent (optional) ----------------------------------------
# Set SERVER_AI_KEY to offer a free, no-key-needed agent powered by YOUR key,
# metered against a per-visitor token allowance. Tip: a Google Gemini key
# (AIza…) has a permanently free tier, making this genuinely free to run.
# When the allowance is used up, the agent is paywalled (HTTP 402) and visitors
# upgrade (links below) or paste their own key for unlimited use.
# SERVER_AI_KEY=AIza...                 # or sk-ant-...
FREE_TOKEN_QUOTA=100000                 # free tokens per visitor (in-memory; resets on restart)

# --- Monetization links (optional) -------------------------------------------
# Stripe Payment Links for the paid plans (create at dashboard.stripe.com).
STRIPE_PRO_LINK=
STRIPE_STUDIO_LINK=

# Checkout links for add-ons.
COURSE_LINK=                            # course enrollment / checkout URL
MARKETING_LINK=                         # marketing toolkit checkout URL

# Domain search/registration. Use {domain} as a placeholder for the query, e.g.
# https://www.namecheap.com/domains/registration/results/?domain={domain}
# If unset, the landing page shows a demo availability check + a registrar link.
DOMAIN_SEARCH_LINK=
