# This app is "bring your own key": each visitor enters their OWN Anthropic API
# key in the browser, so the server does NOT need a key of its own. There is
# nothing required to put here.

# Port the server runs on (optional, defaults to 3000)
PORT=3000

# Claude model the agent uses (optional, defaults to claude-sonnet-4-6)
MODEL=claude-sonnet-4-6
